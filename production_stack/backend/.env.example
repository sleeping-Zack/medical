APP_ENV=dev
DEBUG=true

# 本机直连（默认端口）
MYSQL_DSN=mysql+pymysql://medapp:medapp_pwd@127.0.0.1:3306/medapp?charset=utf8mb4
REDIS_URL=redis://127.0.0.1:6379/0
# Windows 未安装 Redis 时设为 true，使用内存模拟（仅开发环境）
REDIS_USE_MOCK=false

# 若使用本仓库 docker-compose，请改为宿主机映射端口，例如：
# MYSQL_DSN=mysql+pymysql://medapp:medapp_pwd@127.0.0.1:3307/medapp?charset=utf8mb4
# REDIS_URL=redis://127.0.0.1:6380/0

# JWT
JWT_SECRET_KEY=PLEASE_CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# SMS
SMS_PROVIDER=mock
SMS_CODE_TTL_SECONDS=300
SMS_CODE_SALT=PLEASE_CHANGE_ME_TOO
SMS_COOLDOWN_SECONDS=60
SMS_HOURLY_LIMIT=5
SMS_DAILY_LIMIT=10

# Tencent SMS (reserved)
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# Aliyun SMS (reserved)
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
